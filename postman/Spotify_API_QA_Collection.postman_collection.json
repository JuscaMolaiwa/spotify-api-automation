          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/artists/{{ARTIST_ID}}/top-tracks?market={{MARKET}}",
              "host": ["{{BASE_URL}}"],
              "path": ["artists", "{{ARTIST_ID}}", "top-tracks"],
