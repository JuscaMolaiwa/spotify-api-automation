{
  "info": {
    "_postman_id": "spotify-api-qa-collection-v1",
    "name": "Spotify Web API – QA Collection",
    "description": "Comprehensive Postman collection for testing the Spotify Web API.\nCovers Albums, Artists, Tracks, Search, Playlists, and Authentication.\n\nSetup:\n1. Set CLIENT_ID and CLIENT_SECRET in the collection Variables.\n2. Run the 'Get Access Token' request in the Auth folder – the token is auto-saved.\n3. For user-scoped tests, set USER_ACCESS_TOKEN manually.\n\nAll requests inherit the Bearer token from the collection-level authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{ACCESS_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "BASE_URL",         "value": "https://api.spotify.com/v1" },
    { "key": "ACCOUNTS_URL",     "value": "https://accounts.spotify.com" },
    { "key": "CLIENT_ID",        "value": "YOUR_CLIENT_ID" },
    { "key": "CLIENT_SECRET",    "value": "YOUR_CLIENT_SECRET" },
    { "key": "ACCESS_TOKEN",     "value": "" },
    { "key": "USER_ACCESS_TOKEN","value": "" },
    { "key": "ALBUM_ID",         "value": "4LH4d3cOWNNsVw41Gqt2kv" },
    { "key": "ARTIST_ID",        "value": "0k17h0D3J5VfsdmQ1iZtE9" },
    { "key": "TRACK_ID",         "value": "0vFAbKhyBCsFk43sGbHBGR" },
    { "key": "PLAYLIST_ID",      "value": "37i9dQZEVXbMDoHDwVN2tF" },
    { "key": "CREATED_PLAYLIST_ID", "value": "" },
    { "key": "MARKET",           "value": "ZA" }
  ],
  "item": [
    {
      "name": "0. Authentication",
      "item": [
        {
          "name": "Get Access Token (Client Credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has access_token', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.access_token).to.be.a('string').and.not.empty;",
                  "    pm.expect(body.token_type).to.equal('Bearer');",
                  "    pm.expect(body.expires_in).to.equal(3600);",
                  "    pm.collectionVariables.set('ACCESS_TOKEN', body.access_token);",
                  "    console.log('Access token saved to collection variable.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" },
                { "key": "client_id",  "value": "{{CLIENT_ID}}" },
                { "key": "client_secret", "value": "{{CLIENT_SECRET}}" }
              ]
            },
            "url": "{{ACCOUNTS_URL}}/api/token",
            "description": "Obtains a Client Credentials access token and stores it as ACCESS_TOKEN collection variable."
          }
        },
        {
          "name": "Get Token – Invalid Credentials (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 for invalid credentials', () => pm.response.to.have.status(400));",
                  "pm.test('Error field is present', () => {",
                  "    pm.expect(pm.response.json().error).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",    "value": "client_credentials" },
                { "key": "client_id",     "value": "invalid_id" },
                { "key": "client_secret", "value": "invalid_secret" }
              ]
            },
            "url": "{{ACCOUNTS_URL}}/api/token"
          }
        },
        {
          "name": "API Call with Invalid Token (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 for invalid token', () => pm.response.to.have.status(401));",
                  "pm.test('Error status is 401', () => {",
                  "    pm.expect(pm.response.json().error.status).to.equal(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "INVALID_TOKEN_12345", "type": "string" }]
            },
            "method": "GET",
            "url": "{{BASE_URL}}/albums/{{ALBUM_ID}}"
          }
        }
      ]
    },
    {
      "name": "1. Albums",
      "item": [
        {
          "name": "Get Album",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has id and type', () => {",
                  "    const b = pm.response.json();",
                  "    pm.expect(b.id).to.equal(pm.collectionVariables.get('ALBUM_ID'));",
                  "    pm.expect(b.type).to.equal('album');",
                  "    pm.expect(b.name).to.be.a('string').and.not.empty;",
                  "    pm.expect(b.total_tracks).to.be.above(0);",
                  "});",
                  "pm.test('Artists array is not empty', () => {",
                  "    pm.expect(pm.response.json().artists).to.be.an('array').that.is.not.empty;",
                  "});",
                  "pm.test('URI has correct format', () => {",
                  "    pm.expect(pm.response.json().uri).to.match(/^spotify:album:/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/albums/{{ALBUM_ID}}?market={{MARKET}}",
              "host": ["{{BASE_URL}}"],
              "path": ["albums", "{{ALBUM_ID}}"],
              "query": [{ "key": "market", "value": "{{MARKET}}" }]
            }
          }
        },
        {
          "name": "Get Album – Invalid ID (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for invalid ID', () => pm.response.to.have.status(400));",
                  "pm.test('Error status field is 400', () => {",
                  "    pm.expect(pm.response.json().error.status).to.equal(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/albums/INVALID_ID_FOR_TESTING"
          }
        },
        {
          "name": "Get Multiple Albums",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Albums array has correct length', () => {",
                  "    pm.expect(pm.response.json().albums).to.be.an('array').with.lengthOf(3);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/albums?ids=4LH4d3cOWNNsVw41Gqt2kv,2ANVost0y2y52ema1E9xAZ,0ETFjACtuP2ADo6LFhL6HN",
              "host": ["{{BASE_URL}}"],
              "path": ["albums"],
              "query": [{ "key": "ids", "value": "4LH4d3cOWNNsVw41Gqt2kv,2ANVost0y2y52ema1E9xAZ,0ETFjACtuP2ADo6LFhL6HN" }]
            }
          }
        },
        {
          "name": "Get Album Tracks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Track list is paginated', () => {",
                  "    const b = pm.response.json();",
                  "    pm.expect(b.items).to.be.an('array').that.is.not.empty;",
                  "    pm.expect(b.total).to.be.above(0);",
                  "    pm.expect(b.limit).to.equal(5);",
                  "    pm.expect(b.offset).to.equal(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/albums/{{ALBUM_ID}}/tracks?limit=5&offset=0",
              "host": ["{{BASE_URL}}"],
              "path": ["albums", "{{ALBUM_ID}}", "tracks"],
              "query": [
                { "key": "limit",  "value": "5" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Artists",
      "item": [
        {
          "name": "Get Artist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
