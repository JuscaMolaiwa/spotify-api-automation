          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/artists/{{ARTIST_ID}}"
          }
        },
        {
          "name": "Get Artist Albums",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Albums returned as paginated list', () => {",
                  "    const b = pm.response.json();",
                  "    pm.expect(b.items).to.be.an('array').that.is.not.empty;",
                  "    pm.expect(b.total).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/artists/{{ARTIST_ID}}/albums?include_groups=album&limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["artists", "{{ARTIST_ID}}", "albums"],
              "query": [
                { "key": "include_groups", "value": "album" },
                { "key": "limit",          "value": "10" }
              ]
            }
          }
        },
